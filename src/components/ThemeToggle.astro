---
/* ThemeToggle.astro - Final Clean Component */
---

<button id="theme-toggle" aria-label="Toggle Light/Dark Mode">
  <svg id="theme-toggle-light-icon" class="hidden icon" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
    <path d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464l-.707-.707a1 1 0 00-1.414 1.414l.707.707a1 1 0 001.414-1.414zm2.12 10.607a1 1 0 010-1.414l.706-.707a1 1 0 111.414 1.414l-.707.707a1 1 0 01-1.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1z"></path>
  </svg>
  <svg id="theme-toggle-dark-icon" class="hidden icon" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
    <path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"></path>
  </svg>
</button>

<style>
  #theme-toggle {
    border: none;
    background: transparent;
    cursor: pointer;
    padding: 10px;
    border-radius: 50%;
    transition: background-color 0.3s ease, transform 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1001; /* Ensure it stays above other elements */
  }

  #theme-toggle:hover {
    background-color: rgba(148, 163, 184, 0.2);
    transform: rotate(15deg) scale(1.1);
  }

  .icon {
    width: 24px;
    height: 24px;
    color: var(--text-primary); /* Automatically updates based on theme */
  }

  .hidden { 
    display: none !important; 
  }
</style>

<script is:inline>
  function initTheme() {
    const themeToggleDarkIcon = document.getElementById('theme-toggle-dark-icon');
    const themeToggleLightIcon = document.getElementById('theme-toggle-light-icon');
    const themeToggleBtn = document.getElementById('theme-toggle');

    if (!themeToggleBtn) return;

    // 1. Set initial state correctly
    const isLight = localStorage.getItem('color-theme') === 'light' || 
                   (!('color-theme' in localStorage) && window.matchMedia('(prefers-color-scheme: light)').matches);
    
    if (isLight) {
      document.documentElement.classList.add('light');
      themeToggleDarkIcon?.classList.remove('hidden');
      themeToggleLightIcon?.classList.add('hidden');
    } else {
      document.documentElement.classList.remove('light');
      themeToggleLightIcon?.classList.remove('hidden');
      themeToggleDarkIcon?.classList.add('hidden');
    }

    // 2. Clear previous listeners and add the new one
    // This part is crucial for making sure clicking doesn't break other page scripts
    const handleToggle = () => {
      const isNowLight = document.documentElement.classList.toggle('light');
      
      document.getElementById('theme-toggle-dark-icon')?.classList.toggle('hidden');
      document.getElementById('theme-toggle-light-icon')?.classList.toggle('hidden');

      localStorage.setItem('color-theme', isNowLight ? 'light' : 'dark');
    };

    themeToggleBtn.removeEventListener('click', handleToggle);
    themeToggleBtn.addEventListener('click', handleToggle);
  }

  // Run on page load
  initTheme();

  // Run after Astro page swaps (View Transitions)
  document.addEventListener('astro:after-swap', initTheme);
</script>